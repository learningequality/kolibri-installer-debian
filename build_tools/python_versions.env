# Python version configuration for kolibri-installer-debian
# This file is sourced by build and install scripts.
#
# To update, run: make update-python VERSION=3.xx
# Or manually update all fields below.

PYTHON_VERSION="3.10.20"
PYTHON_BUILD_STANDALONE_TAG="20260510"
PYTHON_BUILD_STANDALONE_VERSION="3.10.20+20260510"
PYTHON_SHA256_X86_64="dc734bdd388975c0b093fe730b272af741a2e192475d38bc6845a687b6405922"
PYTHON_SHA256_AARCH64="9f0becaa10fff71a455dcc9f4343cd784ee506a63d770d87fe92030cb376feee"
PYTHON_URL_BASE="https://github.com/astral-sh/python-build-standalone/releases/download"

# Minimum Python version required by Kolibri.
# If the system Python is >= this version, the bundled Python is not installed.
PYTHON_MIN_MAJOR=3
PYTHON_MIN_MINOR=10
